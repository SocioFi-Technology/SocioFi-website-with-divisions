# ──────────────────────────────────────────────────────────────────────────────
# SocioFi Technology — Environment Variables
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to version control.
# ──────────────────────────────────────────────────────────────────────────────


# ── Site ──────────────────────────────────────────────────────────────────────

# The canonical public URL of the site (no trailing slash).
# Used for OG meta, sitemap, and absolute URL generation.
NEXT_PUBLIC_SITE_URL=https://sociofitechnology.com

# Set to "production" | "development" | "test"
# (Next.js sets NODE_ENV automatically; you rarely need this manually)
# NODE_ENV=development


# ── Supabase ──────────────────────────────────────────────────────────────────
# Get these from: https://supabase.com/dashboard → Settings → API

# Public keys — safe to expose in the browser bundle (NEXT_PUBLIC_ prefix)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Service role key — SERVER-SIDE ONLY. Never expose to the browser.
# Used by CMS API routes and admin operations that bypass Row Level Security.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-secret-key

# Optional: JWT secret for custom auth validation (Settings → API → JWT Settings)
# SUPABASE_JWT_SECRET=your-jwt-secret


# ── Sanity CMS ────────────────────────────────────────────────────────────────
# Get these from: https://www.sanity.io/manage → your project → Settings → API

# Project ID (visible in the Sanity dashboard URL and Settings)
NEXT_PUBLIC_SANITY_PROJECT_ID=your-sanity-project-id

# Dataset name — default is "production"
NEXT_PUBLIC_SANITY_DATASET=production

# Read token — for fetching draft/unpublished content in preview mode (server-side only)
SANITY_API_READ_TOKEN=your-sanity-read-token

# Write token — only needed if you programmatically write to Sanity (e.g. from API routes)
# SANITY_API_WRITE_TOKEN=your-sanity-write-token


# ── Anthropic (PILOT AI + NEXUS agent system) ─────────────────────────────────
# Get this from: https://console.anthropic.com → API Keys
# SERVER-SIDE ONLY. Never prefix with NEXT_PUBLIC_.

ANTHROPIC_API_KEY=sk-ant-api03-your-key-here

# Optional: override the default model used by PILOT and NEXUS agents
# ANTHROPIC_MODEL=claude-opus-4-5


# ── Resend (transactional email + newsletter sending) ─────────────────────────
# Get this from: https://resend.com/api-keys
# SERVER-SIDE ONLY.

RESEND_API_KEY=re_your-resend-api-key

# The verified "From" address configured in your Resend domain settings
RESEND_FROM_EMAIL=hello@sociofitechnology.com
RESEND_FROM_NAME=SocioFi Technology

# Optional: separate from-address for newsletters
# RESEND_NEWSLETTER_FROM=digest@sociofitechnology.com


# ── Admin Panel Auth ──────────────────────────────────────────────────────────
# The /admin panel uses Supabase Auth. These are only needed if you configure
# additional auth methods or a separate admin JWT.

# Secret used to sign admin session tokens (generate with: openssl rand -base64 32)
ADMIN_JWT_SECRET=your-random-32-char-secret-here

# Optional: bypass auth for local dev (set to "true" only in .env.local, never production)
# ADMIN_AUTH_BYPASS=false


# ── Cron / Scheduled Tasks ────────────────────────────────────────────────────
# Vercel Cron uses this secret to authenticate requests to /api/* cron endpoints.
# Set the same value in Vercel project settings under Environment Variables.
# Generate with: openssl rand -hex 32

CRON_SECRET=your-cron-secret-here


# ── Analytics (optional) ──────────────────────────────────────────────────────
# Plausible Analytics (privacy-friendly, no cookies)
# Get your domain from: https://plausible.io/sites
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=sociofitechnology.com

# Or Umami (self-hosted alternative)
# NEXT_PUBLIC_UMAMI_WEBSITE_ID=your-umami-website-id
# NEXT_PUBLIC_UMAMI_URL=https://analytics.yourdomain.com


# ── Contact Forms ─────────────────────────────────────────────────────────────
# If using Formspree for the public contact form:
# NEXT_PUBLIC_FORMSPREE_ID=your-formspree-form-id

# If using your own API route (default), no extra vars needed —
# the route uses RESEND_API_KEY above to send email.


# ── Vercel (deployment) ───────────────────────────────────────────────────────
# These are injected automatically by Vercel — do NOT set them manually:
#   VERCEL_URL          → auto (e.g. your-project.vercel.app)
#   VERCEL_ENV          → auto (production | preview | development)
#   VERCEL_GIT_COMMIT_SHA → auto

# Optional: Vercel Deploy Hook URL for on-demand ISR revalidation from Sanity webhooks
# VERCEL_DEPLOY_HOOK_URL=https://api.vercel.com/v1/integrations/deploy/your-hook-id


# ──────────────────────────────────────────────────────────────────────────────
# QUICK START CHECKLIST
# ──────────────────────────────────────────────────────────────────────────────
# [ ] Create a Supabase project at supabase.com and copy URL + anon key
# [ ] Copy service role key (Settings → API — keep it secret!)
# [ ] Create a Sanity project at sanity.io and copy project ID
# [ ] Get an Anthropic API key at console.anthropic.com (for PILOT + NEXUS)
# [ ] Create a Resend account and add/verify your sending domain
# [ ] Set ADMIN_JWT_SECRET to a random 32-char string
# [ ] Set CRON_SECRET to a random 32-char string
# [ ] Add all production values to Vercel project → Settings → Environment Variables
# ──────────────────────────────────────────────────────────────────────────────
