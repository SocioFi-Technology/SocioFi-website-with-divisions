# Supabase — use SERVICE ROLE key (agents bypass RLS)
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-secret-key

# Anthropic — all 13 NEXUS agents use this
ANTHROPIC_API_KEY=sk-ant-api03-your-key-here
ANTHROPIC_MODEL=claude-opus-4-6  # default; override with claude-sonnet-4-6 to reduce cost
AGENT_MAX_RETRIES=3
AGENT_RETRY_DELAY=5

# Resend — outbound email
RESEND_API_KEY=re_your_resend_api_key
RESEND_FROM_EMAIL=noreply@sociofitechnology.com
RESEND_FROM_NAME=SocioFi Technology

# Redis — Celery broker and result backend
# Local: redis://localhost:6379/0
# Docker: redis://redis:6379/0
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# Security — shared with Next.js NEXUS_API_KEY
NEXUS_API_KEY=your-nexus-api-key-here

# Site URLs
SITE_URL=https://sociofitechnology.com
ADMIN_URL=https://superadmin.sociofitechnology.com

# SLA defaults (hours)
SLA_P1_HOURS=1
SLA_P2_HOURS=4
SLA_P3_HOURS=24
SLA_P4_HOURS=72

# SCRIBE: hours before due date to auto-draft content
SCRIBE_LEAD_HOURS=48

# CHRONICLE — comma-separated list of founder emails to receive daily/weekly/monthly reports
CHRONICLE_RECIPIENTS=arifur@sociofitechnology.com,kamrul@sociofitechnology.com

# Server
PORT=8001
DEBUG=false
